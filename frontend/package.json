{
  "name": "ai-coder",
  "displayName": "AI Coder Agent",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning"
  ],
  "main": "./out/extension.js",
  
  
"activationEvents": [
    "*"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-coder-sidebar",
          "title": "AI Coder",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "ai-coder-sidebar": [
        {
          "type": "webview",
          "id": "ai-coder.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "ai-coder.start",
        "title": "Start AI Coder"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node ./node_modules/vscode/bin/test"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.7"
  }
}