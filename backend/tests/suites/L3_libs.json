    "description": "NumPy column-wise normalization.",
    "query": "Write a function `normalize_columns(matrix)` that normalizes each column of a 2D NumPy array by subtracting the mean and dividing by the standard deviation of that column. Ensure you handle cases where the standard deviation is zero (constant column) by returning zeros for that column to avoid division by zero errors.",
    "context_files": [],
    "expected_intent": 2,
    "type": "code",
    "metrics": {
      "must_contain": ["np.mean", "np.std", "axis=0"],
      "execution": {
        "run_tests": [
          "import numpy as np",
          "func = globals().get('normalize_columns')",
          "assert func is not None, 'Function normalize_columns not found'",
          "",
          "m1 = np.array([[10, 2], [20, 4], [30, 6]])",
          "res1 = func(m1)",
          "assert np.allclose(res1.mean(axis=0), 0), 'Mean of normalized columns should be 0'",
          "assert np.allclose(res1.std(axis=0), 1), 'Std of normalized columns should be 1'",
          "",
          "m2 = np.array([[5, 10], [5, 20], [5, 30]])",
          "res2 = func(m2)",
          "assert np.all(res2[:, 0] == 0), f'Constant column should result in zeros to avoid NaN, got {res2[:, 0]}'",
          "assert np.allclose(res2[:, 1].std(), 1), 'Other columns should still be normalized correctly'"
        ]
      }
    }
