          "",
          "m1 = np.array([[10, 10], [20, 20]])",
          "v1 = np.array([1, 2])",
          "res1 = func(m1, v1)",
          "assert np.array_equal(res1[0], [9, 8]), f'Row 0 failed: expected [9, 8], got {res1[0]}'",
