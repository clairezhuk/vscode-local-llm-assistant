def ucb1(node_win_rate, node_visits, total_parent_visits, exploration_weight=1.41):
    """
    Calculate the UCB1 score for MCTS node selection.

    Parameters:
        node_win_rate (float): The win rate of the current node.
        node_visits (int): The number of times the current node has been visited.
        total_parent_visits (int): The total number of visits to all nodes in the tree.
        exploration_weight (float): The exploration weight, default is 1.41.

    Returns:
        float: The UCB1 score for the current node.
    """
    # Calculate the win rate ratio
    win_rate_ratio = node_win_rate / node_visits
    
    # Calculate the total visits to all nodes in the tree
    total_visits = total_parent_visits + node_visits
    
    # Calculate the UCB1 score
    ucb_score = win_rate_ratio + exploration_weight * (math.sqrt(math.log(total_visits) / node_visits))
    
    return ucb_score
