    new_y = sum(rotation_matrix[0][i] * x + rotation_matrix[1][i] * y + rotation_matrix[2][i] * z for i in range(3))
    new_z = sum(rotation_matrix[0][i] * x + rotation_matrix[1][i] * y + rotation_matrix[2][i] * z for i in range(3))
    
    return (new_x, new_y, new_z)
