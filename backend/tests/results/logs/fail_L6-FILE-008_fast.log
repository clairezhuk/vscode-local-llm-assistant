def find_deepest_readme(tree):
    def traverse(node, path):
        if node is None:
            return None
        if 'test_README.md' in node:
            return path + ['test_README.md']
        left_path = traverse(node['left'], path + ['left'])
        right_path = traverse(node['right'], path + ['right'])
        if left_path and right_path:
            return left_path if len(left_path) > len(right_path) else right_path
        elif left_path:
            return left_path
        elif right_path:
            return right_path
        return None

    return traverse(tree, [])
