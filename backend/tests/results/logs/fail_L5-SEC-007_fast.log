import os

def get_safe_path(base_dir, user_file):
    # Check if the user file starts with the base directory
    if not user_file.startswith(base_dir):
        return None
    
    # Use os.path.abspath to ensure the path is absolute and safe from '../' attacks
    safe_path = os.path.abspath(user_file)
    
    return safe_path
