import os

def get_safe_path(base_dir, user_file):
    # Ensure base_dir is absolute
    base_dir = os.path.abspath(base_dir)
    
    # Check if user_file starts with base_dir
    if user_file.startswith(base_dir):
        return os.path.abspath(user_file)
    else:
        return None
