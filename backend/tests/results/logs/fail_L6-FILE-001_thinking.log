import json

def change_port_to_5432(file_path):
    # Load the JSON data from the file
    with open(file_path, 'r') as file:
        config_data = json.load(file)

    # Find the 'database.port' in the data
    for key, value in config_data.items():
        if key == 'database' and 'port' in value:
            value['port'] = 5432
            break

    # Save the modified data back to the file with indentation
    with open(file_path, 'w') as file:
        json.dump(config_data, file, indent=4)

# Example usage
