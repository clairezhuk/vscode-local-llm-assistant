from pathlib import Path
import datetime

def rename_files_with_date():
    uploads_folder = Path('C:\\Users\\user\\AppData\\Local\\Temp\\tmpjwdpjn05\\uploads')
    
    # Get the current date in YYYY-MM-DD format
    current_date = datetime.datetime.now().strftime('%Y-%m-%d')
    
    # List all .jpg and .png files in the uploads folder
    jpg_files = list(uploads_folder.glob('*.jpg'))
    png_files = list(uploads_folder.glob('*.png'))
    
    # Rename each file with the current date as a prefix
    for file in jpg_files + png_files:
        new_name = f"{current_date}_{file.name}"
        file.rename(file.with_name(new_name))
        
    return "Files renamed successfully."
