import numpy as np

def get_row_max_indices(matrix):
    """
    Returns the indices of the maximum values in each row of a 2D NumPy array.

    Args:
    matrix (np.ndarray): A 2D NumPy array.

    Returns:
    list: A list of lists, where each inner list contains the indices of the maximum value in the corresponding row.
    """
    # Find the indices of the maximum values in each row
    max_indices = np.argmax(matrix, axis=1)
    
    return max_indices.tolist()
