def find_largest_element(lst):
    if not lst:  # Check if the list is empty
        return None
    
    current_max = lst[0]  # Initialize the current maximum with the first element
    
    for element in lst[1:]:  # Start from the second element
        if element > current_max:
            current_max = element  # Update the current maximum if a larger element is found
    
    return current_max
