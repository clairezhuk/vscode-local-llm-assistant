import torch
import torch.nn as nn
import torch.nn.functional as F

def train_step(model, optimizer, criterion, x, y):
    """
    Performs one optimization step for a model.
    
    Args:
    model (nn.Module): The PyTorch model to be trained.
    optimizer (torch.optim.Optimizer): The optimizer for the model.
    criterion (torch.nn.modules.loss): The loss function.
    x (torch.Tensor): Input tensor of size (batch_size, 10).
    y (torch.Tensor): Target tensor of size (batch_size, 1).
    
    Returns:
    torch.Tensor: The loss after one optimization step.
    """
    # Zero the gradients of the model
    optimizer.zero_grad()
    
    # Perform the forward pass
    y_pred = model(x)
    
    # Calculate the loss
    loss = criterion(y_pred, y)
    
    # Compute the backward pass
    loss.backward()
    
    # Perform the optimizer step
    optimizer.step()
    
    # Return the loss after one optimization step
    return loss
```

