from typing import List

def extract_unique_ips(log_file: str) -> List[str]:
    with open(log_file, 'r') as file:
        ip_addresses = [line.split()[0] for line in file if line.startswith('192.168')]
    return sorted(ip_addresses)

def main() -> None:
    log_file = 'access.log'
