def grid_shortest_path(grid, start, end):
    rows, cols = len(grid), len(grid[0])
    directions = [(0, 1), (0, -1), (1, 0), (-1, 0)]
    
    # Initialize a queue for BFS and a dictionary to keep track of the parent node
    queue = [start]
    parent = {start: None}
    
    while queue:
        current = queue.pop(0)
        
        if current == end:
            path_length = 0
            while current is not None:
                path_length += 1
                current = parent[current]
            return path_length
        
        for dx, dy in directions:
            new_x, new_y = current[0] + dx, current[1] + dy
            
            if 0 <= new_x < rows and 0 <= new_y < cols and grid[new_x][new_y] == 0 and (new_x, new_y) not in parent:
                queue.append((new_x, new_y))
                parent[(new_x, new_y)] = current
    
    return -1
