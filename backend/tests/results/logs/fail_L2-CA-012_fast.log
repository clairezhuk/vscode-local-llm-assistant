def grid_shortest_path(grid, start, end):
    # Initialize the queue with the starting position and a path length of 0
    queue = [(start, 0)]
    
    # Dictionary to keep track of visited positions and their paths
    visited = {start: (None, 0)}
    
    while queue:
        current_position, path_length = queue.pop(0)
        
        if current_position == end:
            return path_length
        
        # Explore all four possible moves (up, down, left, right)
        for dx, dy in [(0, 1), (0, -1), (-1, 0), (1, 0)]:
            new_x, new_y = current_position[0] + dx, current_position[1] + dy
            
            # Check if the new position is within bounds and not a wall
            if 0 <= new_x < len(grid) and 0 <= new_y < len(grid[0]) and grid[new_x][new_y] == 0:
                # If the new position has not been visited or the path to it is shorter, update the queue and visited dictionary
                if (new_x, new_y) not in visited or path_length + 1 < visited[(new_x, new_y)][1]:
                    visited[new_x, new_y] = (current_position, path_length + 1)
                    queue.append((new_x, new_y))
    
    # If no path is found, return -1
    return -1
