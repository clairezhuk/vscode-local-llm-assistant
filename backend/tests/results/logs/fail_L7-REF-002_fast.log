import time

def log_time(func):
    def wrapper(*args, **kwargs):
        start = time.time()
        result = func(*args, **kwargs)
        end = time.time()
        print(f"{func.__name__} executed in {end - start}s")
        return result
    return wrapper

@log_time
def process_request(data):
    time.sleep(0.1)
    print(f"Request processed: {data}")

@log_time
def fetch_user_profile(user_id):
    time.sleep(0.05)
    print(f"User {user_id} fetched")
