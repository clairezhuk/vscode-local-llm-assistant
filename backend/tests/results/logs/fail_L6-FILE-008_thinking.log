def find_deepest_readme(tree):
    def traverse(node, path=''):
        if node is None:
            return
        if 'test_README.md' in node:
            return path + '/test_README.md'
        for key, value in node.items():
            result = traverse(value, path + '/' + key)
            if result is not None:
                return result
    return traverse(tree)
