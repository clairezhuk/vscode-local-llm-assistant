import matplotlib.pyplot as plt

def create_plot(x, y):
    """
    Generates a line plot with specified x and y data.
    
    Parameters:
    - x: A list or array of x-coordinates for the plot.
    - y: A list or array of y-coordinates for the plot.
    
    Returns:
    None
    """
    plt.plot(x, y)
    plt.title('Data Plot')
    plt.xlabel('X-axis Label')
    plt.ylabel('Y-axis Label')
    plt.legend()
    plt.show()

# Example usage:
x_values = [1, 2, 3, 4, 5]
y_values = [2, 3, 5, 7, 11]
create_plot(x_values, y_values)
