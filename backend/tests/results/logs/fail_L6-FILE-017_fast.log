ERROR: FileNotFoundError: [Errno 2] No such file or directory: 'combined.log'
RESPONSE:
```python
import os

def merge_txt_files():
    combined_content = ""
    
    # Get all .txt files in the current directory
    txt_files = [f for f in os.listdir() if f.endswith('.txt')]
    
    for file_name in txt_files:
        with open(file_name, 'r', encoding='utf-8') as file:
            content = file.read()
            combined_content += content + '\n'  # Add a newline to separate files
    
    # Write the combined content to a new file
    with open('combined.log', 'w', encoding='utf-8') as combined_file:
        combined_file.write(combined_content)
    
    return "Combined log created successfully."
```