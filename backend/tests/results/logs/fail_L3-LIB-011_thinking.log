import os
import shutil

def clean_code():
    # Define the source directory containing the files to be processed
    source_dir = 'path/to/source/directory'
    
    # Define the destination directory where the processed files will be saved
    destination_dir = 'path/to/destination/directory'
    
    # Ensure the destination directory exists
    if not os.path.exists(destination_dir):
        os.makedirs(destination_dir)
    
    # List all files in the source directory
    files = os.listdir(source_dir)
    
    # Iterate through each file in the source directory
    for file in files:
        # Construct the full path to the file
        file_path = os.path.join(source_dir, file)
        
        # Check if the file is a regular file (not a directory)
        if os.path.isfile(file_path):
            # Construct the destination path for the processed file
            destination_file_path = os.path.join(destination_dir, file)
            
            # Copy the file to the destination directory
            shutil.copy2(file_path, destination_file_path)
            print(f'Successfully saved {file} to {destination_file_path}') 
    
    print('All files have been saved successfully.')

clean_code()
```

