import numpy as np

def subtract_vector_from_matrix(matrix, vector):
    """
    Subtract a given vector from each row of the matrix using broadcasting.
    
    Parameters:
    - matrix: A 2D numpy array representing the matrix.
    - vector: A 1D numpy array representing the vector to be subtracted.
    
    Returns:
    - A new 2D numpy array with the vector subtracted from each row of the original matrix.
    """
    # Subtract the vector from each row using broadcasting
    result = matrix - vector[:, None]
    return result

# Example usage
matrix = np.array([[1, 2, 3], [4, 5, 6]])
vector = np.array([7, 8, 9])
result = subtract_vector_from_matrix(matrix, vector)
print(result)
