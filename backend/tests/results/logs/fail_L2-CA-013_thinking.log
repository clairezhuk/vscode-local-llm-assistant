# Define a function to parse nested logs and store the data in a dictionary
def parse_logs(logs):
    # Initialize an empty dictionary to store module statuses
    module_statuses = {}
    
    for log_entry in logs:
        # Split the log entry into components (module name, status)
        parts = log_entry.split()
        
        # Extract the module name and status from the parts
        module_name = parts[0]
        status = parts[1]
        
        # If the module is already in the dictionary, update its status
        if module_name in module_statuses:
            module_statuses[module_name] += f", {status}"
        else:
            # Otherwise, add the module and its initial status to the dictionary
            module_statuses[module_name] = status
    return module_statuses

# Example usage of the function
