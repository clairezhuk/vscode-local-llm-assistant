def parse_nested_logs(lines):
    log_dict = {}
    for line in lines:
        if 'Module[' in line and ': Status[' in line:
            parts = line.split(': ')
            module_name = parts[0].split('[')[1]
            log_dict[module_name] = parts[1]
    return log_dict
