    "Module1: Running",
    "Module2: Stopped",
    "Module1: Paused",
    "Module3: Running"
]

print(parse_logs(logs))

# Import re for regular expressions
import re

def parse_nested_logs(logs):
    # Regular expression to match module statuses in logs
    pattern = r'(\w+): (\d+)'
    
    # Initialize an empty dictionary to store module statuses
    module_statuses = {}
    
    # Iterate over each log line
    for line in logs:
        # Find all matches of the pattern in the current line
        matches = re.findall(pattern, line)
        
        # If there are matches, update the module statuses dictionary
        if matches:
            for match in matches:
                module_name, status = match
                if module_name not in module_statuses:
                    module_statuses[module_name] = []
                module_statuses[module_name].append(status)
    return module_statuses

# Example usage
logs = [
    "Module1: 20",
    "Module2: 30",
    "Module1: 40",
    "Module3: 50",
    "Module2: 60"
]

parsed_data = parse_nested_logs(logs)
print(parsed_data)
