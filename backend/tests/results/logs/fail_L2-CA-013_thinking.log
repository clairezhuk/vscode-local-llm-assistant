import re

def parse_nested_logs(logs):
    # Initialize an empty dictionary to store module statuses
    module_statuses = {}
    
    for line in logs:
        # Extract module name and status using regular expressions
        match = re.search(r'(\w+) (Active|Inactive|Running|Stopped)', line)
        if match:
            module_name, status = match.groups()
            # Store the status under the module name in a dictionary
            module_statuses[module_name] = status
    return module_statuses

