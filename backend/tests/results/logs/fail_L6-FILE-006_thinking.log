from pathlib import Path
import datetime

# Step 1: Define the base path for the uploads folder
uploads_folder = Path("uploads")

# Step 2: Retrieve a list of all files with the specified extensions
jpg_files = uploads_folder.glob("*.jpg")
png_files = uploads_folder.glob("*.png")

# Step 3: Rename each file by adding the current date as a prefix
for file in jpg_files + png_files:
    # Step 4: Create a new file name with the current date prefix
    new_file_name = f"{datetime.datetime.now().strftime('%Y-%m-%d')}{file.suffix}"
    
    # Step 5: Rename the file
    file.rename(new_file_name)

    # Log the successful renaming
    print(f"Renamed {file.name} to {new_file_name}")
