from pathlib import Path
import datetime

def rename_files_with_datetime(directory):
    try:
        for file_path in directory.iterdir():
            if file_path.is_file() and (file_path.suffix == '.jpg' or file_path.suffix == '.png'):
                new_name = f"{datetime.datetime.now().strftime(\'%Y%m%d%H%M%S\')}_{file_path.name}"
                new_path = Path(directory / new_name)
                old_path = Path(file_path)
                old_path.rename(new_path)
                print(f"Renamed {old_path} to {new_path}")
    except FileNotFoundError:
        print("Directory not found.")
    except PermissionError:
        print("Permission denied.")
    except Exception as e:
        print(f"An error occurred: {e}")

# Example usage
directory_path = Path('path/to/your/directory')
rename_files_with_datetime(directory_path)
```


