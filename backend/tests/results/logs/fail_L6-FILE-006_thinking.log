from pathlib import Path, FileNotFoundError

def rename_files_with_date_prefix(directory):
    try:
        # Ensure the directory exists
        directory = Path(directory)
        if not directory.exists():
            raise FileNotFoundError(f"Directory {directory} does not exist.")
        
        # List all files in the directory
        for file_path in directory.iterdir():
            if file_path.is_file():
                # Extract the base name and extension of the file
                base_name, ext = file_path.stem, file_path.suffix
                
                # Generate a new date prefix
                current_date = Path().strftime("%Y%m%d")
                
                # Construct the new file path with the date prefix
                new_file_path = directory / f"{current_date}_{base_name}{ext}"
                
                # Rename the file
                file_path.rename(new_file_path)
                print(f"Renamed {file_path} to {new_file_path}")
    except FileNotFoundError as e:
        print(e)
    except Exception as e:
        print(f"An error occurred: {e}")

# Example usage
directory = Path("path/to/your/directory")
rename_files_with_date_prefix(directory)
