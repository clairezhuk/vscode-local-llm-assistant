```python
from pathlib import Path, FileNotFoundError

def list_files(directory):
    return [f for f in directory.iterdir() if f.is_file()]

def rename_files(files, prefix):
    for file in files:
        new_name = f"{prefix}_{file.name}"
        file.rename(new_name)

def main():
    try:
        # Step 1: Define the directory path
        directory_path = Path("path/to/your/directory")
        
        # Step 2: List all files in the directory
        files = list_files(directory_path)
        
        # Step 3: Choose a prefix for renaming (e.g., "file_")
        prefix = "file_"
        
        # Step 4: Call the rename function
        rename_files(files, prefix)
        
        print("Files renamed successfully.")
    except FileNotFoundError as e:
        print(f"Directory not found: {e}")
    except Exception as e:
        print(f"An error occurred: {e}")

if __name__ == "__main__":
    main()
