from pathlib import Path, datetime

# Step 4: Iterate over each file in the directory
for file_path in Path.cwd().iterdir():
    # Check if the item is a file (not a directory)
    if file_path.is_file():
        try:
            # Get the current date and time
            now = datetime.now()
            
            # Create a new file name with the date prefix
            new_name = f"{now.strftime(\'%Y%m%d%H%M%S\')}_{file_path.name}"
            
            # Rename the file
            file_path.rename(new_name)
            print(f"Renamed: {file_path.name} to {new_name}")
        except Exception as e:
            print(f"Error renaming {file_path.name}: {e}")
