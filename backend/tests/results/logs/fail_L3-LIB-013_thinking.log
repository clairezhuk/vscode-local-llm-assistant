import numpy as np

def normalize_columns(matrix):
    """Normalizes each column of a 2D NumPy array by subtracting the mean and dividing by the standard deviation."""
    
    # Calculate the mean of each column
    means = np.mean(matrix, axis=0)
    
    # Calculate the standard deviation of each column
    stds = np.std(matrix, axis=0)
    
    # Normalize each column by subtracting the mean and dividing by the standard deviation
    normalized_matrix = (matrix - means) / stds
    
    return normalized_matrix
