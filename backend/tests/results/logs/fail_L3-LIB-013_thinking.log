import os

def list_files_without_tmp(directory_path):
    # Step: Define the directory path where the files are located
    directory_path = 'C:\\\\path\\\\to\\\\directory'

    # Step: Ensure the directory exists
    if not os.path.exists(directory_path):
        print(f"Directory {directory_path} does not exist.")
        return []

    # Step: Create a list to store the file paths that match the pattern
    filtered_files = []

    # Step: Loop through each file in the directory
    for filename in os.listdir(directory_path):
        # Step: Check if the file name matches the pattern '*.txt'
        if filename.endswith('.txt'):
            # Step: Append the full file path to the filtered_files list
            filtered_files.append(os.path.join(directory_path, filename))

    # Step: Write the filtered file paths to a new file named 'filtered_files.txt'
    with open('filtered_files.txt', 'w') as file:
        for file_path in filtered_files:
            file.write(file_path + '\n')

    # Step: Print a confirmation message
    print(f"Filtered file paths have been written to 'filtered_files.txt'.")
    return filtered_files

# Example usage
filtered_files = list_files_without_tmp('C:\\\\path\\\\to\\\\directory')
