import numpy as np

def normalize_columns(matrix):
    """
    Normalizes each column of a 2D NumPy array by subtracting the mean and dividing by the standard deviation.
    
    Parameters:
    matrix (np.ndarray):. Step: Calculate the standard deviation of each column. Code only.\n    """\n    std_dev = np.std(matrix, axis=0)\n    normalized_matrix = (matrix - np.mean(matrix, axis=0)) / std_dev\n    return normalized_matrix
