import torch.nn as nn

class SimpleNet(nn.Module):
    def __init__(self):
        super(SimpleNet, self).__init__()
        # Define the first linear layer with ReLU activation
        self.fc1 = nn.Linear(10, 20)
        # Define the second linear layer without activation (output layer)
        self.fc2 = nn.Linear(20, 1)

    def forward(self, x):
        # Pass input through the first linear layer and apply ReLU activation
        out = self.fc1(x)
        out = torch.relu(out)
        # Pass the output of the first layer to the second linear layer without activation
        out = self.fc2(out)
        return out
