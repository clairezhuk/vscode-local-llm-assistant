import matplotlib.pyplot as plt

def plot_two_charts(data1, data2):
    """
    Plots two sets of data on a single figure with 1 row and 2 columns.
    
    Parameters:
    - data1: A list or array of numerical values representing the first set of data.
    - data2: A list or array of numerical values representing the second set of data.
    """
    fig, axs = plt.subplots(1, 2)
    
    # Plotting the first set of data
    axs[0].plot(data1)
    axs[0].set_title('Data Set 1')
    
    # Plotting the second set of data
    axs[1].plot(data2)
    axs[1].set_title('Data Set 2')
    
    plt.tight_layout()
    plt.show()
```


