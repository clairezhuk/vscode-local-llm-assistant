import matplotlib.pyplot as plt

def plot_two_charts(data1, data2):
    """
    Plots two datasets on a single figure with 1 row and 2 columns of subplots.
    
    Parameters:
        data1 (array-like): The first dataset to be plotted.
        data2 (array-like): The second dataset to be plotted.
    """
    fig, axs = plt.subplots(1, 2)
    
    # Plotting data1 on the first subplot
    axs[0].plot(data1)
    axs[0].set_title('Data 1')
    
    # Plotting data2 on the second subplot
    axs[1].plot(data2)
    axs[1].set_title('Data 2')
    
    plt.tight_layout()
    plt.show()
```


