```python
import matplotlib.pyplot as plt

def plot_data(list1, list2):
    """Plot two lists of numerical data on separate subplots in a 1x2 layout."""
    plt.figure(figsize=(10, 5))
    
    for i, (data1, data2) in enumerate(zip(list1, list2)):
        plt.subplot(1, 2, i+1)
        plt.plot(data1, label=f'Data {i+1}')
        plt.plot(data2, label=f'Data {i+1}')
        plt.title(f'Data {i+1}')
        plt.xlabel('Index')
        plt.ylabel('Value')
        plt.legend()
        plt.grid(True)
    
    plt.tight_layout()
    plt.show()
```

