import torch

def train_step(model, optimizer, criterion, x, y):
    # Zero the gradients of the model parameters
    optimizer.zero_grad()
    
    # Forward pass: compute predicted outputs by passing input through the model
    outputs = model(x)
    
    # Calculate the loss between predicted and actual values
    loss = criterion(outputs, y)
    
    # Backward pass: compute gradients of the loss with respect to the model parameters
    loss.backward()
    
    # Perform a single optimization step
    optimizer.step()

# Example usage:
model = torch.nn.Linear(10, 2)  # Simple linear model for demonstration
optimizer = torch.optim.SGD(model.parameters(), lr=0.01)
criterion = torch.nn.MSELoss()  # Mean Squared Error loss function

x = torch.randn(10, 10)  # Input data
y = torch.randn(10, 2)   # Target data

train_step(model, optimizer, criterion, x, y)
