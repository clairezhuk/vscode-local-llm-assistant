import torch

def train_step(model, optimizer, criterion, x, y):
    # Zero the gradients of the model parameters
    optimizer.zero_grad()
    
    # Forward pass: compute predicted outputs from the model
    output = model(x)
    
    # Calculate the loss between predicted and actual values
    loss = criterion(output, y)
    
    # Backward pass: compute gradients for all model parameters
    loss.backward()
    
    # Perform a step of optimization using the computed gradients
    optimizer.step()

    return loss.item()  # Return the scalar value of the loss
```