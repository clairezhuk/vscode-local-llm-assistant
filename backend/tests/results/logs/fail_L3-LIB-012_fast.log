import torch

def train_step(model, optimizer, criterion, x, y):
    # Zero gradients of the model parameters
    optimizer.zero_grad()
    
    # Forward pass through the model
    outputs = model(x)
    
    # Calculate loss using the criterion
    loss = criterion(outputs, y)
    
    # Backward pass to compute gradients
    loss.backward()
    
    # Perform a step in the optimization process
    optimizer.step()
    
    return loss.item()
