import torch

def train_step(model, optimizer, criterion, x, y):
    # Zero gradients to prepare for the next iteration
    optimizer.zero_grad()
    
    # Forward pass: compute output predictions from input data
    outputs = model(x)
    
    # Compute loss
    loss = criterion(outputs, y)
    
    # Backward pass: calculate gradients of the loss with respect to parameters
    loss.backward()
    
    # Step the optimizer to update the weights based on the computed gradients
    optimizer.step()
