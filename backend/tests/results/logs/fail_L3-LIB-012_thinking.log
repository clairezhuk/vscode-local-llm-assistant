```python
import torch

def train_step(model, optimizer, criterion, x, y):
    """
    Performs one optimization step: zero gradients, forward pass, calculate loss,
    backward pass, and optimizer step.

    Parameters:
        model (torch.nn.Module): The neural network model.
        optimizer (torch.optim.Optimizer): The optimizer to update the model's weights.
        criterion (torch.nn.modules.loss._Loss): The loss function.
        x (torch.Tensor): Input data tensor.
        y (torch.Tensor): Target data tensor.

    Returns:
        None
    """
    # Zero out the gradients of the model parameters
    optimizer.zero_grad()

    # Forward pass: compute output from the model
    output = model(x)

    # Calculate the loss between the predicted and actual values
    loss = criterion(output, y)

    # Backward pass: compute gradients for the model parameters
    loss.backward()

    # Update the model's weights using the optimizer
    optimizer.step()
```


