import numpy as np

def subtract_row_vec(matrix, vec):
    """
    Subtract a 1D vector from each row of a 2D NumPy array using broadcasting.

    Parameters:
    matrix (np.ndarray): A 2D NumPy array of shape (M, N).
    vec (np.ndarray): A 1D NumPy array of shape (N,) representing the vector to subtract.

    Returns:
    np.ndarray: A 2D NumPy array with each row subtracted by the vector.
    """
    # Subtract the vector from each row using broadcasting
    result = matrix - vec[:, np.newaxis]
    return result

# Example usage
matrix = np.array([[1, 2, 3], [4, 5, 6]])
vec = np.array([7, 8, 9])
result = subtract_row_vec(matrix, vec)
print(result)  # Output: [[-6 -6 -6]
                 #          [-3 -3 -3]]
