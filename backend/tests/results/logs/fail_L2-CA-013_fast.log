import re

def parse_nested_logs(lines):
    log_dict = {}
    for line in lines:
        match = re.search(r'Module\[(.*?)\]: Status\[(.*?)\]', line)
        if match:
            module_name, status_value = match.groups()
            if module_name not in log_dict:
                log_dict[module_name] = []
            log_dict[module_name].append(status_value)
    return log_dict
