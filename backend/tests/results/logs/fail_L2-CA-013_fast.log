import re

def parse_nested_logs(lines):
    log_pattern = r'Module\[(.*?)\]: Status\[(.*?)\]'
    matches = {}
    
    for line in lines:
        match = re.search(log_pattern, line)
        if match:
            name = match.group(1)
            value = match.group(2)
            matches[name] = value
    
    return matches
