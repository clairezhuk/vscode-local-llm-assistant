def binary_search(arr, x):
    l, r = 0, len(arr) - 1
    while l <= r:
        mid = (l + r) // 2
        if arr[mid] == x: return mid
        elif arr[mid] < x: l = mid + 1 # Corrected here to move right
        else: r = mid - 1
    return -1
