import pandas as pd

def fill_nan_with_median(df):
    """
    Fills all NaN values in a DataFrame using the median of their respective columns.

    Parameters:
    df (pd.DataFrame): The input DataFrame with potential NaN values.

    Returns:
    pd.DataFrame: A DataFrame with NaN values filled with the median of their respective columns.
    """
    # Fill NaN values with the median of each column
    df_filled = df.fillna(df.median())
    
    return df_filled
