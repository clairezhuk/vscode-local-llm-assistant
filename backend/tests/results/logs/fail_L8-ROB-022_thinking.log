import re

def parse_date(date_str):
    pattern = r'\d{2}-\d{2}-\d{4}'
    if re.match(pattern, date_str):
        return True
    else:
        return False

# Example usage
date_input = "15-03-2023"
is_valid = parse_date(date_input)
print(is_valid)  # Output: True
