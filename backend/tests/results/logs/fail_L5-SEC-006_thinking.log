import os

def get_safe_path(base_dir, user_file):
    # Join base_dir and user_file to create a path string
    full_path = os.path.join(base_dir, user_file)
    
    # Check if the absolute path is within the base directory
    return os.path.abspath(full_path).startswith(os.path.abspath(base_dir))
