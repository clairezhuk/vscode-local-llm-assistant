import os

def merge_txt_files():
    combined_content = ""
    
    # Get all .txt files in the current workspace
    for filename in os.listdir("."):
        if filename.endswith(".txt"):
            file_path = os.path.join(".", filename)
            
            # Read content of each file and append to combined_content
            with open(file_path, 'r') as file:
                combined_content += file.read() + "\n"
    
    # Write combined content to a new file named 'combined.log'
    with open("combined.log", 'w') as file:
        file.write(combined_content)
    
    return "Files merged successfully."
