import datetime

def format_date(timestamp):
    return datetime.datetime.fromtimestamp(timestamp).strftime('%Y-%m-%d %H:%M:%S')

def process_timestamps(timestamps):
    formatted_timestamps = [format_date(timestamp) for timestamp in timestamps]
    return formatted_timestamps

# Example usage:
timestamps = [1633072800, 1633159200, 1633245600]
formatted_timestamps = process_timestamps(timestamps)
print(formatted_timestamps)
