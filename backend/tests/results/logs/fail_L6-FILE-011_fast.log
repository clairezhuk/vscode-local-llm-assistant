import csv

def calculate_average_amount(file_path):
    total_amount = 0
    count = 0
    
    with open(file_path, mode='r', newline='') as file:
        reader = csv.DictReader(file)
        for row in reader:
            amount = float(row['Amount'])
            total_amount += amount
            count += 1
    
    if count > 0:
        average_amount = total_amount / count
        return average_amount
    else:
        return None

file_path = 'C:\\Users\\user\\AppData\\Local\\Temp\tmpp3pchih4\\sales.csv'
average_amount = calculate_average_amount(file_path)
print(f"The average amount is: {average_amount}")
