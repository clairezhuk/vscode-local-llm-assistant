import csv

# Open the sales.csv file in read mode
with open('sales.csv', 'r') as file:
    # Create a CSV reader object
    reader = csv.reader(file)
    
    # Skip the header row
    next(reader)
    
    # Initialize a list to store the 'Amount' values
    amount_values = []
    
    # Iterate over each row in the CSV
    for row in reader:
        # Append the 'Amount' value to the list
        amount_values.append(float(row[1]))
    
    # Calculate the average value of the 'Amount' column
    average_amount = sum(amount_values) / len(amount_values)
    
    # Return the average value
    return average_amount
