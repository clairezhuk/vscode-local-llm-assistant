# Workspace initialization
import os
import shutil
import os

# Check existing files in a directory
def check_existing_files(directory):
    existing_files = []
    for root, dirs, files in os.walk(directory):
        for file in files:
            if os.path.isfile(os.path.join(root, file)):
                existing_files.append(os.path.join(root, file))
    return existing_files

# Example usage
directory_path = '/path/to/your/directory'
existing_files = check_existing_files(directory_path)
print("Existing files in the directory:", existing_files)

# Step 1: Copy Existing Files
source_folder = 'existing_folder'
destination_folder = 'new_folder'
os.makedirs(destination_folder, exist_ok=True)
for root, dirs, files in os.walk(source_folder):
    for file in files:
        source_file_path = os.path.join(root, file)
        destination_file_path = os.path.join(destination_folder, file)
        shutil.copy2(source_file_path, destination_file_path)
print("Files copied successfully from", source_folder, "to", destination_folder)

# Create a new directory
directory_name = "NewDirectory"
os.makedirs(directory_name, exist_ok=True)

# Set the permissions for the current directory to read, write, and execute
os.chmod('.', 0o777)

print("Success")
