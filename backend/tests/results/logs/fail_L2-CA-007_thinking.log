import re

def parse_log_errors(logs):
    entries = []
    for line in logs.split('\\n'):
        if 'ERROR' in line:
            date, level, message = re.match(r'\d{4}-\d{2}-\d{2} \w+ \w+', line).groups()
            entries.append({'date': date, 'level': level, 'message': message})
    return entries
