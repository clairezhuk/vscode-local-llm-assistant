import re

def parse_log_errors(logs):
    pattern = r'\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] (\w+) (.*)'
    return [match.groupdict() for match in re.finditer(pattern, logs)]
