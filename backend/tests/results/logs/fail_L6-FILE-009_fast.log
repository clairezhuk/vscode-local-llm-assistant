import csv

def calculate_avg(file_path):
    total_amount = 0
    count = 0
    
    with open(file_path, mode='r', newline='') as file:
        reader = csv.DictReader(file)
        for row in reader:
            total_amount += float(row['Amount'])
            count += 1
            
    if count == 0:
        return None  # No data to calculate average
    else:
        return total_amount / count

# Example usage
file_path = 'C:\\Users\\user\\AppData\\Local\\Temp\\tmp5b6gn_wf\\sales.csv'
average_amount = calculate_avg(file_path)
print(f"The average amount is: {average_amount}")
