import torch
from torch.utils.data import Dataset

class MyDataset(Dataset):
    """
    A dataset class for PyTorch that takes a list of numbers and returns them as a float tensor.

    Parameters:
        numbers (list): A list of numbers.

    Returns:
        None
    """
    def __init__(self, numbers):
        self.numbers = numbers

    def __len__(self):
        return len(self.numbers)

    def __getitem__(self, index):
        return torch.tensor(self.numbers[index], dtype=torch.float)
```

