import os

def move_to_backup(source_file, destination_path):
    # Ensure the destination path ends with a slash for proper directory handling
    if not destination_path.endswith('/'):
        destination_path += '/'
    
    # Use os.path.join to combine the source file and the destination path
    backup_file = os.path.join(destination_path, source_file)
    
    # Perform the file move operation
    try:
        os.rename(source_file, backup_file)
        print(f"Backup file created: {backup_file}")
    except Exception as e:
        print(f"Error moving file: {e}")
```

