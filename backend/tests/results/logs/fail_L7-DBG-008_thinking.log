### Attempt 2
```python
import os

def move_to_backup(file_path, backup_path):
    """Move a file to a backup location using os.path.join.

    Args:
    file_path (str): The path of the file to be moved.
    backup_path (str): The path where the file will be moved to.

    Returns:
    None
    """
    # Ensure the backup path exists
    os.makedirs(os.path.dirname(backup_path), exist_ok=True)
    
    # Use os.path.join to correctly combine paths
    backup_path = os.path.join(backup_path, os.path.basename(file_path))
    
    # Move the file
    os.replace(file_path, backup_path)
```

