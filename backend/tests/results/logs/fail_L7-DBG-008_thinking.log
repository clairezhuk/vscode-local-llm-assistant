### Attempt 3
```python
import os

def move_to_backup(file_path, backup_folder):
    try:
        # Correctly combine the file path with the backup folder using os.path.join
        backup_path = os.path.join(backup_folder, os.path.basename(file_path))
        
        # Check if the backup path already exists
        if os.path.exists(backup_path):
            print(f"Backup file already exists: {backup_path}")
            return
        
        # Move the file to the backup folder
        os.rename(file_path, backup_path)
        print(f"File moved to backup: {backup_path}")
    except Exception as e:
        # Log the error with a meaningful message
        print(f"An error occurred: {e}")
```