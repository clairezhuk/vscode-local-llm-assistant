### Attempt 2

```python
import json

def add_user_to_list(user, items=[]):
    try:
        with open('user_list.txt', 'r') as file:
            existing_items = file.readlines()
        
        for item in existing_items:
            if user == item.strip():
                return "User already exists in the list."
        
        items.append(user)
        with open('user_list.txt', 'w') as file:
            file.writelines(items)
    except FileNotFoundError:
        items = [user]
        with open('user_list.txt', 'w') as file:
            file.writelines(items)

# Example usage
add_user_to_list("Alice")
add_user_to_list("Bob")
```
