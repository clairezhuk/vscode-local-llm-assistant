### Attempt 1
```python
from collections import deque

def find_path(graph, start, goal):
    queue = deque([[start]])
    while queue:
        path = queue.popleft()
        vertex = path[-1]
        if vertex == goal:
            return path[::-1]
        for neighbor in graph[vertex]:
            if neighbor not in path:
                new_path = list(path)
                new_path.append(neighbor)
                queue.append(new_path)
    return []
