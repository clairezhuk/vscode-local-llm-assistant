import java.io.File;

public class DiskSpaceCheck {
    public static void main(String[] args) {
        File folder = new File("C:\\Users\\user\\AppData\\Local\\Temp\\tmpus6_00ru");
        long totalSpace = folder.getTotalSpace();
        long usedSpace = folder.getUsableSpace();
        long freeSpace = totalSpace - usedSpace;

        System.out.println("Total Space: " + formatSize(totalSpace));
        System.out.println("Used Space: " + formatSize(usedSpace));
        System.out.println("Free Space: " + formatSize(freeSpace));
    }

    public static String formatSize(long bytes) {
        if (bytes < 1024) return bytes + " B";
        if (bytes < 1024 * 1024) return String.format("%.2f MB", bytes / (1024 * 1024));
        if (bytes < 1024 * 1024 * 1024) return String.format("%.2f GB", bytes / (1024 * 1024 * 1024));
        return String.format("%.2f TB", bytes / (1024 * 1024 * 1024 * 1024));
    }
}
