import threading
import time

class AsyncDataFetcher:
    def __init__(self, max_operations):
        self.max_operations = max_operations
        self.semaphore = threading.Semaphore(max_operations)
        self.in_flight_operations = 0

    def fetch_data(self, operation_id):
        try:
            with self.semaphore:
                self.in_flight_operations += 1
                print(f"Starting operation {operation_id}")
                time.sleep(1)  # Simulate data fetching
                self.in_flight_operations -= 1
                print(f"Completed operation {operation_id}")
        except Exception as e:
            print(f"Error fetching data: {e}")

# Usage
fetcher = AsyncDataFetcher(3)
fetcher.fetch_data("1")
fetcher.fetch_data("2")
fetcher.fetch_data("3")
time.sleep(1)  # To allow operations to complete before new ones start
fetcher.fetch_data("4")
