import asyncio
from asyncio import Semaphore

class DataFetcher:
    def __init__(self, max_concurrent_operations):
        self.max_concurrent_operations = max_concurrent_operations
        self.semaphore = Semaphore(max_concurrent_operations)

    def fetch_data(self, url):
        with self.semaphore:
            print(f"Fetching data for {url}")
            # Simulate the operation taking some time
            import time
            time.sleep(2)
            print(f"Data fetched successfully for {url}")

async def fetch_operations(urls):
    async with DataFetcher(max_concurrent_operations=5) as fetcher:
        for url in urls:
            await fetcher.fetch_data(url)

async def main():
    urls = ["http://example.com", "http://example.org", "http://example.net", "http://example.com", "http://example.org", "http://example.net"]
    await fetch_operations(urls)

if __name__ == "__main__":
    asyncio.run(main())
