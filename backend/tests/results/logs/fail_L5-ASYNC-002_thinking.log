import asyncio
import os

async def process_file(file_path, semaphore):
    try:
        with open(file_path, 'r') as file:
            # Process the file content
            content = file.read()
            print(f"Processing file: {file_path}")
            # Simulate some processing time
            await asyncio.sleep(1)
    except FileNotFoundError:
        print(f"File not found: {file_path}")
    except Exception as e:
        print(f"Error processing file: {file_path}. {e}")
    finally:
        semaphore.release()

async def main(file_paths, max_concurrent):
    semaphore = asyncio.Semaphore(max_concurrent)
    tasks = [process_file(file_path, semaphore) for file_path in file_paths]
    await asyncio.gather(*tasks)

if __name__ == '__main__':
    file_paths = [
        'path/to/file1.txt',
        'path/to/file2.txt',
        'path/to/file3.txt',  # Repeat this as needed
        # ...
    ]
    max_concurrent = 5
    asyncio.run(main(file_paths, max_concurrent))
