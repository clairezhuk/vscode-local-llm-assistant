```python
import requests

def fetch_with_retry(url):
    for _ in range(3):
        try:
            response = requests.get(url)
            if response.status_code == 200:
                return response.text
            else:
                print(f"Failed with status code {response.status_code}")
        except requests.exceptions.RequestException as e:
            print(f"Error: {e}")
    return None
