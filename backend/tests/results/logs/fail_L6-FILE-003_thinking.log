import os

def assemble_parts(parts):
    assembled_code = ""
    for part in parts:
        if part not in assembled_code:
            assembled_code += part + "\n"
    return assembled_code

# Parts to be assembled
parts = [
    'cd /path/to/workspace',
    'cd /path/to/directory',
    '#!/bin/bash\nwhile IFS= read -r line\ndo\n    if [[ $line == *"[ERROR]"* ]]\n    then\n        echo "$line" >> errors.log\n    fi\ndone < server.log',
    "grep -E '\\[ERROR\\]' server.log > errors.log",
    "grep -i '[ERROR]' server.log > errors.log",
    '#!/bin/bash\n\n# Check if the server.log file exists\nif [ ! -f server.log ]; then\n  echo "Error: server.log file does not exist."\n  exit 1\nfi\n\n# Check if errors.log file exists and is writable\nif [ ! -f errors.log ] || [ ! -w errors.log ]; then\n  echo "Error: errors.log file does not exist or is not writable."\n  exit 1\nfi\n\n# Loop through server.log, extract lines containing \'[ERROR]\', and write to errors.log\nwhile IFS= read -r line; do\n  if [[ $line == *"[ERROR]"* ]]; then\n    echo "$line" >> errors.log\n  fi\ndone < server.log'
]

# Assemble the parts into a single valid Python file
