        with open(os.path.join(directory, file), 'r') as f:
            content = f.read()
            print(f"Contents of {file}:")
            print(content)
            print()  # Add a newline for readability

def get_package_versions(file_contents):
    # Regular expression to find import statements and package versions
    import_pattern = re.compile(r\'from\\s+(\\w+)\\s+import\\s+(\\w+)\', re.IGNORECASE)
    versions = {}
    
    # Iterate through each line in the file
    for line in file_contents.split(\'\\n\'):
        # Find all matching import statements
        for match in import_pattern.finditer(line):
            # Extract the package and version
            package, version = match.groups()
            # Store the version in the dictionary
            versions[package] = version
    return versions

