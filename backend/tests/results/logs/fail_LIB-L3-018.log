import numpy as np

def subtract_row_vec(matrix, vec):
    """
    Subtracts a 1D vector from each row of a 2D array using broadcasting.
    
    Args:
    matrix (np.ndarray): A 2D numpy array from which each row will be subtracted.
    vec (np.ndarray): A 1D numpy array to be subtracted from each row of the matrix.
    
    Returns:
    np.ndarray: A 2D array where each row has been subtracted by the vector.
    """
    # Subtract the vector from each row of the matrix using broadcasting
    result = matrix - vec[:, np.newaxis]
    
    # Return the result
    return result
