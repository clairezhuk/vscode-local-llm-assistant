### Attempt 1

```python
import numpy as np

def assign_clusters(points, centroids):
    clusters = []
    for point in points:
        distances = [np.linalg.norm(point - centroid) for centroid in centroids]
        closest_index = np.argmin(distances)
        clusters.append(closest_index)
    return clusters
