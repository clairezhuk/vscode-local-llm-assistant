def knapsack(weights, values, capacity):
    # Base case: if capacity is zero, return 0
    if capacity == 0:
        return 0
    # Base case: if there are no items to consider, return 0
    if len(weights) == 0:
        return 0
    # Recursive case: decide whether to include the current item in the knapsack
    if weights[0] <= capacity:
        return max(values[0] + knapsack(weights[1:], values[1:], capacity - weights[0]), knapsack(weights[1:], values, capacity))
    else:
        return knapsack(weights[1:], values, capacity)
