from typing import List

def knapsack(capacity: int, weights: List[int], values: List[int]) -> int:
    n = len(weights)
    
    # Create a 2D array to store the maximum value that can be obtained with a given capacity and weight limit
    dp = [[0 for _ in range(capacity + 1)] for _ in range(n + 1)]
    
    # Fill the dp table
    for i in range(1, n + 1):
        for w in range(1, capacity + 1):
            if weights[i - 1] <= w:
                dp[i][w] = max(values[i - 1] + dp[i - 1][w - weights[i - 1]], dp[i - 1][w])
            else:
                dp[i][w] = dp[i - 1][w]
    
    # The maximum value that can be obtained with the given capacity is stored in dp[n][capacity]
    return dp[n][capacity]

# Example usage
weights = [3, 4, 5]
values = [2, 3, 4]
capacity = 7
print(knapsack(weights, values, capacity))  # Output: 9
```
