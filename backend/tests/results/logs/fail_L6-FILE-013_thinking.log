# utils.py
from datetime import datetime

def format_timestamp(timestamp):
    """Formats a timestamp string into a more readable format."""
    return datetime.strptime(timestamp, '%Y-%m-%d %H:%M:%S').strftime('%Y-%m-%d %H:%M:%S')

# Example usage
timestamp = '2023-10-05 14:30:00'
formatted_timestamp = format_timestamp(timestamp)
print(formatted_timestamp)  # Output: 2023-10-05 14:30:00
