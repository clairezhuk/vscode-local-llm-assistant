def merge_txt_files():
    import os

    # List all .txt files in the current workspace
    txt_files = [f for f in os.listdir('.') if f.endswith('.txt')]

    # Open a file to write the merged content
    with open('combined.log', 'w') as combined_file:
        for file_name in txt_files:
            # Read each file and write its content to the combined file
            with open(file_name, 'r') as file:
                combined_file.write(file.read() + '\n')

# Call the function to merge the text files
merge_txt_files()
