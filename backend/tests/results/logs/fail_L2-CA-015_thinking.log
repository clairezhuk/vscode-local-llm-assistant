def scale_points(points, factor):
    """Scale a list of 3D points by a given factor tuple.

    Args:
    points (list of tuples): A list where each tuple represents a 3D point (x, y, z).
    factor (tuple): A tuple of three factors (f1, f2, f3) to scale each dimension.

    Returns:
    list of tuples: The scaled points.
    """
    return [(p[0] * factor[0], p[1] * factor[1], p[2] * factor[2]) for p in points]
