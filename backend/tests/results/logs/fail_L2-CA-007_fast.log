import re

def parse_log_errors(logs):
    # Regular expression to match the log entry format
    pattern = r'\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] \[ERROR\] (.+)'
    
    # Find all matches in the logs
    matches = re.findall(pattern, logs)
    
    # Convert matches to a list of dictionaries
    log_entries = [{'date': date, 'message': message} for date, message in matches]
    
    return log_entries

# Example usage:
logs = """
2023-10-05 14:30:00 [ERROR] Connection failed to server
2023-10-05 14:31:00 [INFO] Server is up and running
2023-10-05 14:32:00 [ERROR] Network issue detected
"""
print(parse_log_errors(logs))
