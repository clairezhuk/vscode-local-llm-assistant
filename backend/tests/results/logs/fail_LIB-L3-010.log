import torch
import torch.nn as nn
import torch.nn.functional as F

class SimpleNet(nn.Module):
    """
    A simple neural network with two linear layers (input size 10, hidden size 20, output size 1) with a ReLU activation between them.
    """
    def __init__(self):
        """
        Initialize the SimpleNet module.
        """
        super(SimpleNet, self).__init__()
        
        # Define the first linear layer
        self.fc1 = nn.Linear(10, 20)
        
        # Define the second linear layer
        self.fc2 = nn.Linear(20, 1)
        
        # Define the ReLU activation function
        self.relu = nn.ReLU()
    
    def forward(self, x):
        """
        Forward pass through the network.
        
        Args:
        x (torch.Tensor): Input tensor of size (batch_size, 10).
        
        Returns:
        torch.Tensor: Output tensor of size (batch_size, 1).
        """
        # Pass through the first linear layer
        x = self.fc1(x)
        
        # Apply ReLU activation
        x = self.relu(x)
        
        # Pass through the second linear layer
        x = self.fc2(x)
        
        # Return the output tensor
        return x
