import torch.nn as nn

def get_probabilities(logits):
    """
    Convert the logits to probabilities using a suitable function.
    
    Args:
        logits (torch.Tensor): The input logits, which are expected to be in the range [-inf, inf].
        
    Returns:
        torch.Tensor: The corresponding probabilities after applying the softmax function.
    """
    # Apply the softmax function to convert logits to probabilities
    probabilities = nn.functional.softmax(logits, dim=1)
    
    return probabilities
