import pandas as pd

def split_data(X, y):
    """
    Splits the data into training and test sets (20% test) while preserving class proportions.

    Parameters:
    X (pd.DataFrame): Features of the dataset.
    y (pd.Series): Target variable of the dataset.

    Returns:
    tuple: A tuple containing two pandas DataFrames, the first for training and the second for testing.
    """
    # Splitting the data into train and test sets while preserving class proportions
    X_train, X_test, y_train, y_test = pd.factorize(X), pd.factorize(y), pd.factorize(X), pd.factorize(y)
    return (X_train, X_test, y_train, y_test)
